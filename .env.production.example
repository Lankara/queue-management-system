# Root Docker Compose production environment template.
# Copy to .env.production on the Oracle VM and replace every placeholder.

NODE_ENV=production

# Public domains. Replace with your real domain records.
# DNS must point both to the Oracle VM public IP before Caddy can issue HTTPS certificates.
APP_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
CADDY_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api
CORS_ORIGIN=https://yourdomain.com

# PostgreSQL container bootstrap values.
# Use a long random password. Do not reuse this outside this deployment.
POSTGRES_DB=queue_management_db
POSTGRES_USER=qms_app
POSTGRES_PASSWORD=replace-with-long-random-postgres-password

# API database connection inside Docker network.
DATABASE_URL=postgresql://qms_app:replace-with-long-random-postgres-password@postgres:5432/queue_management_db
DATABASE_SSL=false

# Strong random JWT secret. Example generation: openssl rand -base64 48
JWT_SECRET=replace-with-strong-random-jwt-secret
JWT_EXPIRES_IN=1d

# Request and public endpoint safety.
API_JSON_BODY_LIMIT=1mb
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=60
WHATSAPP_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# WhatsApp outbound/inbound defaults. Keep disabled until Meta credentials are ready.
WHATSAPP_PROVIDER=whatsapp-cloud-api
WHATSAPP_ENABLED=false
WHATSAPP_DEV_MODE=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_DEFAULT_COUNTRY_CODE=94
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-webhook-verify-token
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_INBOUND_DEV_MODE=true
WHATSAPP_DEFAULT_BUSINESS_SLUG=

# Worker defaults. Enable only after API auth token strategy is configured.
WORKER_API_BASE_URL=http://api:4000/api
WORKER_API_ACCESS_TOKEN=
NOTIFICATION_WORKER_ENABLED=false
NOTIFICATION_WORKER_POLL_INTERVAL_MS=15000
NOTIFICATION_WORKER_BATCH_SIZE=25
NOTIFICATION_WORKER_RETRY_DELAY_MS=5000
NOTIFICATION_WORKER_HEARTBEAT_EVERY_POLLS=10