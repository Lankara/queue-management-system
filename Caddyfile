# Queue Management System production Caddyfile.
# Set APP_DOMAIN in .env.production, for example:
#   APP_DOMAIN=lankara.duckdns.org
# DNS must point APP_DOMAIN to the Oracle VM public IP.
# Caddy automatically obtains and renews HTTPS certificates from Let's Encrypt.

{
    email {$CADDY_EMAIL}
}

{$APP_DOMAIN} {
    encode zstd gzip

    log {
        output stdout
        format console
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    @api path /api /api/*
    reverse_proxy @api api:4000

    reverse_proxy web:3000
}