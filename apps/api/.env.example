# Security-sensitive values. Keep real production values out of source control.
PORT=4000
NODE_ENV=development
API_JSON_BODY_LIMIT=1mb

# CORS: use comma-separated explicit origins. Do not use wildcard in production.
CORS_ORIGIN=http://localhost:3000

# Public endpoint rate limits are in-memory MVP limits per IP + method + path.
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=60
WHATSAPP_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# Required in all environments. Use SSL options at the deployment layer as needed.
DATABASE_URL=postgresql://postgres:password@localhost:5432/queue_management_db
DATABASE_SSL=false

# JWT_SECRET is required in production. Use a strong secret from a secret manager.
JWT_SECRET=change-this-dev-secret
JWT_EXPIRES_IN=1d

WHATSAPP_PROVIDER=whatsapp-cloud-api
WHATSAPP_ENABLED=false
WHATSAPP_DEV_MODE=true
# Required only when WHATSAPP_ENABLED=true and WHATSAPP_DEV_MODE=false.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_DEFAULT_COUNTRY_CODE=94

NOTIFICATION_WORKER_ENABLED=false
NOTIFICATION_WORKER_POLL_INTERVAL_MS=15000

WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-webhook-token
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_INBOUND_DEV_MODE=true
WHATSAPP_DEFAULT_BUSINESS_SLUG=city-care-medical
