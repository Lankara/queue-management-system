# API production environment template.
# Used by docker-compose.prod.yml as an app-level env file.

NODE_ENV=production
PORT=4000
API_JSON_BODY_LIMIT=1mb

# Lock CORS to the public web domain. Comma-separated origins are supported.
CORS_ORIGIN=https://yourdomain.com

DATABASE_URL=postgresql://qms_app:replace-with-long-random-postgres-password@postgres:5432/queue_management_db
DATABASE_SSL=false

JWT_SECRET=replace-with-strong-random-jwt-secret
JWT_EXPIRES_IN=1d

PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=60
WHATSAPP_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

WHATSAPP_PROVIDER=whatsapp-cloud-api
WHATSAPP_ENABLED=false
WHATSAPP_DEV_MODE=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_DEFAULT_COUNTRY_CODE=94
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-webhook-verify-token
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_INBOUND_ENABLED=false
WHATSAPP_INBOUND_DEV_MODE=true
WHATSAPP_DEFAULT_BUSINESS_SLUG=